---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const values = [
  {
    title: 'Honestidad',
    description: 'Te decimos exactamente qué necesita tu vehículo y por qué. Sin cargos ocultos ni sorpresas.',
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Calidad',
    description: 'Usamos repuestos de calidad y herramientas profesionales. Tu seguridad es lo primero.',
    icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z',
  },
  {
    title: 'Compromiso',
    description: 'Cumplimos con los tiempos acordados y garantizamos todos nuestros trabajos.',
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Atención Personalizada',
    description: 'Cada cliente y cada vehículo son diferentes. Te escuchamos y te damos la mejor solución.',
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
  },
];
---

<Layout title="Sobre Nosotros">
  <Header />

  <main>
    <section class="bg-slate-900 py-16 md:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Sobre Nosotros</h1>
        <p class="text-lg text-slate-300 max-w-2xl mx-auto">
          Conocé la historia de Mecánica Ríos y por qué somos la elección de confianza en Monte Grande.
        </p>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="aspect-video bg-slate-200 rounded-xl flex items-center justify-center">
              <div class="text-center p-8">
                <svg class="w-16 h-16 text-slate-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <p class="text-sm text-slate-500">Foto del taller (reemplazar)</p>
              </div>
            </div>
          </div>

          <div>
            <h2 class="text-3xl font-bold text-slate-900 mb-4">Nuestra Historia</h2>
            <p class="text-slate-600 leading-relaxed mb-4">
              Mecánica Ríos nació de la pasión por los automóviles y el compromiso con la excelencia. 
              Desde nuestros inicios, nos propusimos ser un taller diferente: uno donde la honestidad 
              y la calidad sean la norma, no la excepción.
            </p>
            <p class="text-slate-600 leading-relaxed mb-4">
              Ubicados en Monte Grande, Buenos Aires, atendemos a clientes de toda la zona sur 
              del Gran Buenos Aires. Nuestro objetivo es simple: que cada persona que confía 
              su vehículo en nuestras manos se vaya segura y conforme.
            </p>
            <p class="text-slate-600 leading-relaxed">
              Contamos con herramientas modernas, repuestos de calidad y un equipo capacitado 
              para resolver desde el problema más simple hasta la reparación más compleja.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-slate-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-slate-900 mb-4">Nuestros Valores</h2>
          <p class="text-lg text-slate-600 max-w-2xl mx-auto">
            Los principios que guían cada trabajo que hacemos.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {values.map((value) => (
            <div class="p-6 bg-white rounded-xl border border-slate-200 text-center">
              <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={value.icon} />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-slate-900 mb-2">{value.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          <div>
            <div class="text-4xl font-bold text-blue-700 mb-2">10+</div>
            <div class="text-sm text-slate-600">Años de Experiencia</div>
          </div>
          <div>
            <div class="text-4xl font-bold text-blue-700 mb-2">500+</div>
            <div class="text-sm text-slate-600">Clientes Satisfechos</div>
          </div>
          <div>
            <div class="text-4xl font-bold text-blue-700 mb-2">100%</div>
            <div class="text-sm text-slate-600">Trabajos Garantizados</div>
          </div>
          <div>
            <div class="text-4xl font-bold text-blue-700 mb-2">24h</div>
            <div class="text-sm text-slate-600">Respuesta Rápida</div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
