---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const works = [
  {
    title: 'Restauración Motor Ford Falcon',
    description: 'Reconstrucción completa de motor 3.0 con cambio de pistones, aros y rectificación de culata.',
    category: 'Mecánica General',
    beforeImg: '/placeholder.svg',
    afterImg: '/placeholder.svg',
  },
  {
    title: 'Cambio de Frenos Toyota Corolla',
    description: 'Reemplazo de pastillas, discos y líquido de frenos. Ajuste y prueba de eficiencia.',
    category: 'Frenos',
    beforeImg: '/placeholder.svg',
    afterImg: '/placeholder.svg',
  },
  {
    title: 'Suspensión Renault Clio',
    description: 'Cambio de amortiguadores traseros, resortes y rótulas. Geometría completa.',
    category: 'Suspensión',
    beforeImg: '/placeholder.svg',
    afterImg: '/placeholder.svg',
  },
  {
    title: 'Service Completo Volkswagen Gol',
    description: 'Mantenimiento de 50 puntos con cambio de aceite, filtros y revisión de fluidos.',
    category: 'Service',
    beforeImg: '/placeholder.svg',
    afterImg: '/placeholder.svg',
  },
  {
    title: 'Reparación Eléctrica Chevrolet Corsa',
    description: 'Cambio de alternador, batería y revisión de sistema de iluminación completo.',
    category: 'Electricidad',
    beforeImg: '/placeholder.svg',
    afterImg: '/placeholder.svg',
  },
  {
    title: 'Aire Acondicionado Fiat Palio',
    description: 'Recarga de gas refrigerante, reparación de compresor y detección de fugas.',
    category: 'Aire Acondicionado',
    beforeImg: '/placeholder.svg',
    afterImg: '/placeholder.svg',
  },
];
---

<Layout title="Galería de Trabajos">
  <Header />

  <main>
    <section class="bg-slate-900 py-16 md:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Galería de Trabajos</h1>
        <p class="text-lg text-slate-300 max-w-2xl mx-auto">
          Algunos de los trabajos realizados en nuestro taller. 
          Reemplazá las imágenes placeholder por fotos reales de los trabajos de tu hermano.
        </p>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {works.map((work) => (
            <div class="bg-white rounded-xl border border-slate-200 overflow-hidden hover:shadow-lg transition-all">
              <div class="grid grid-cols-2 gap-1 bg-slate-100">
                <div class="aspect-square bg-slate-200 flex items-center justify-center">
                  <div class="text-center p-4">
                    <svg class="w-12 h-12 text-slate-400 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <span class="text-xs text-slate-500">Foto "antes"</span>
                  </div>
                </div>
                <div class="aspect-square bg-slate-200 flex items-center justify-center">
                  <div class="text-center p-4">
                    <svg class="w-12 h-12 text-slate-400 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <span class="text-xs text-slate-500">Foto "después"</span>
                  </div>
                </div>
              </div>
              <div class="p-6">
                <span class="inline-block px-2 py-1 text-xs font-medium text-blue-700 bg-blue-50 rounded-full mb-2">
                  {work.category}
                </span>
                <h3 class="text-lg font-bold text-slate-900 mb-2">{work.title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{work.description}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-12 p-6 bg-amber-50 rounded-xl border border-amber-200">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 text-amber-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <h3 class="font-bold text-amber-900">¿Cómo agregar fotos reales?</h3>
              <p class="text-sm text-amber-800 mt-1">
                1. Sacá fotos "antes" y "después" de cada trabajo.<br/>
                2. Guardalas en la carpeta <code class="bg-amber-100 px-1 rounded">public/trabajos/</code>.<br/>
                3. Editá este archivo y reemplazá las rutas de las imágenes.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
