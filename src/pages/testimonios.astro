---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const testimonials = [
  {
    name: 'Carlos G.',
    vehicle: 'Ford Focus 2015',
    text: 'Excelente atención. Arreglaron el motor de mi auto en tiempo récord y con precio justo. Los recomiendo totalmente.',
    rating: 5,
    date: 'Marzo 2024',
  },
  {
    name: 'María L.',
    vehicle: 'Toyota Etios 2019',
    text: 'Muy profesionales. Me explicaron todo lo que le hicieron al auto antes de empezar. Me sentí en confianza todo el tiempo.',
    rating: 5,
    date: 'Febrero 2024',
  },
  {
    name: 'Roberto S.',
    vehicle: 'Renault Clio 2012',
    text: 'El único taller en Monte Grande donde me siento tranquilo dejando mi vehículo. Honestos y eficientes.',
    rating: 5,
    date: 'Enero 2024',
  },
  {
    name: 'Ana P.',
    vehicle: 'Volkswagen Gol 2017',
    text: 'Hice el service completo y quedé muy conforme. Me entregaron un informe detallado de todo lo que revisaron.',
    rating: 5,
    date: 'Diciembre 2023',
  },
  {
    name: 'Jorge M.',
    vehicle: 'Chevrolet Corsa 2010',
    text: 'Me arreglaron un problema eléctrico que otros talleres no pudieron resolver. Muy capaces.',
    rating: 5,
    date: 'Noviembre 2023',
  },
  {
    name: 'Laura D.',
    vehicle: 'Fiat Palio 2014',
    text: 'Les hice recargar el aire acondicionado y quedó perfecto. Precio justo y atención rápida.',
    rating: 4,
    date: 'Octubre 2023',
  },
];
---

<Layout title="Testimonios">
  <Header />

  <main>
    <section class="bg-slate-900 py-16 md:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Testimonios</h1>
        <p class="text-lg text-slate-300 max-w-2xl mx-auto">
          La opinión de nuestros clientes es lo más importante. 
          Gracias por confiar en Mecánica Ríos.
        </p>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {testimonials.map((t) => (
            <div class="p-6 bg-slate-50 rounded-xl border border-slate-200">
              <div class="flex gap-1 mb-4">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg class={`w-5 h-5 ${i < t.rating ? 'text-yellow-400' : 'text-slate-300'}`} fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="text-slate-700 mb-4 leading-relaxed">"{t.text}"</p>
              <div class="pt-4 border-t border-slate-200">
                <p class="font-medium text-slate-900">{t.name}</p>
                <p class="text-sm text-slate-500">{t.vehicle} · {t.date}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 bg-blue-50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl font-bold text-slate-900 mb-4">¿Sos cliente?</h2>
        <p class="text-slate-600 mb-6">
          Tu opinión nos ayuda a crecer. Dejanos tu testimonio y aparecerá en esta sección.
        </p>
        <a
          href="/mecanica-rios/contacto"
          class="inline-flex items-center px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors"
        >
          Dejar Testimonio
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
