---
interface Props {
  href: string;
  class?: string;
  target?: string;
  rel?: string;
}

const { href, class: className, target, rel } = Astro.props;
const base = import.meta.env.BASE_URL;
const isExternal = href.startsWith('http') || href.startsWith('mailto:') || href.startsWith('tel:');
const finalHref = isExternal ? href : (href === '/' ? base : base + href);
---

<a href={finalHref} class={className} target={target} rel={rel}>
  <slot />
</a>
